
@{
    ViewBag.Title = "Usuarios";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item"><a href="index.html" data-translate="breadcrumb_summary">Resumen</a></li>
    <li class="breadcrumb-item active" data-translate="breadcrumb_users">Usuarios</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-users me-1"></i>
        <span data-translate="user_list">Lista de Usuarios</span>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-12">
                <button type="button" class="btn btn-warning" onclick="AbrirModelo(null)">
                    <i class="fas fa-user-plus"></i> <span data-translate="btn_new_user">Crear nuevo usuario</span>
                </button>
            </div>
        </div>

        <hr />
        <table id="Tabla1" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th data-translate="col_name">Nombres</th>
                    <th data-translate="col_lastname">Apellidos</th>
                    <th data-translate="col_email">Correo</th>
                    <th data-translate="col_active">Activo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="ModeloFormulario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="exampleModalLabel" data-translate="user_modal_title">Usuario</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input id="txtid" type="hidden" value="0" />

                <div class="row g-2">
                    <div class="col-sm-6">
                        <label for="txtnombres" class="form-label" data-translate="label_name">Nombres</label>
                        <input type="text" class="form-control" id="txtnombres" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="txtapellidos" class="form-label" data-translate="label_lastname">Apellidos</label>
                        <input type="text" class="form-control" id="txtapellidos" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="txtcorreo" class="form-label" data-translate="label_email">Correo</label>
                        <input type="email" class="form-control" id="txtcorreo" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="cboactivo" class="form-label" data-translate="label_active">Activo</label>
                        <select class="form-select" id="cboactivo">
                            <option value="1" data-translate="option_yes">Si</option>
                            <option value="0" data-translate="option_no">No</option>
                        </select>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-12">
                        <div id="MensajeError" class="alert alert-danger" role="alert" data-translate="error_generic">
                            A simple danger alert—check it out!
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                    <span data-translate="btn_close">Cerrar</span>
                </button>
                <button type="button" class="btn btn-success" onclick="Guardar()">
                    <span data-translate="btn_save">Guardar</span>
                </button>
            </div>
        </div>
    </div>
</div>




<!---Todo lo que se escriba aca lo va a heredar el Master Page(Que esta en _Layout.cshtml)-->
@section scripts {
    <script>

    var TablaDatos;
        var filaSeleccionada;

        // Detecta el idioma actual (por si estás en inglés o español)
        var idiomaActual = localStorage.getItem("idioma") || "es";

        // URLs de idioma para DataTables
        var urlsIdiomas = {
            "es": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/es-ES.json",
            "en": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/en-GB.json"
        };

     // # Identificador para el atributo Id
    TablaDatos = $("#Tabla1").DataTable({
        ajax: {
            url: '@Url.Action("ListarUsuarios", "Home")',
            type: 'GET',
            dataType: 'json'
        },
        columns: [
            { data: "Nombres" },
            { data: "Apellidos" },
            { data: "Correo" },
            {
                data: "Activo",
                render: function (data) {
                    if (data) {
                        return '<span class="badge rounded-pill bg-success">Si</span>';
                    } else {
                        return '<span class="badge rounded-pill bg-danger">No</span>';
                    }
                }
            },
            {
                defaultContent:
                    '<button type="button" class="btn btn-warning btn-sm btn-modificar"><i class="fas fa-pen"></i></button>' +
                    '<button type="button" class="btn btn-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash"></i></button>',
                orderable: false,
                searchable: false,
                width: "90px"
            }
        ],
        language: {
            url: urlsIdiomas[idiomaActual]
        }
    });

      // Abrir Modelo va a recibir un objeto llamado json que es mi "data"
    function AbrirModelo(json) {
        $("#txtid").val("0");
        $("#txtnombres").val("");
        $("#txtapellidos").val("");
        $("#txtcorreo").val("");
        $("#cboactivo").val(1);
        $("#MensajeError").hide();

        if (json != null) {
            $("#txtid").val(json.IdUsuario);
            $("#txtnombres").val(json.Nombres);
            $("#txtapellidos").val(json.Apellidos);
            $("#txtcorreo").val(json.Correo);
            $("#cboactivo").val(json.Activo === true ? 1 : 0);
        }

        $("#ModeloFormulario").modal("show");
    }

    // Botón Modificar
    $("#Tabla1 tbody").on("click", '.btn-modificar', function () {
        filaSeleccionada = $(this).closest("tr");
        var data = TablaDatos.row(filaSeleccionada).data();
        AbrirModelo(data);
    });


        // Botón Eliminar
        $("#Tabla1 tbody").on("click", '.btn-eliminar', function () {
            var usuarioseleccionado = $(this).closest("tr");
            var data = TablaDatos.row(usuarioseleccionado).data();

            swal({
                title: 'Estas seguro?',
                text: '¿Deseas eliminar este usuario?',
                type: 'warning',
                showCancelButton: true,
                confirmButtonClass: 'btn-primary',
                confirmButtonText: 'Si',
                cancelButtonText: 'No',
                closeOnConfirm: true
            },
            function () {

                jQuery.ajax({
                    url: '@Url.Action("EliminarUsuarios", "Home")',
                    type: 'POST',
                    data: JSON.stringify({id: data.IdUsuario}),
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    // este data esta almacenando la respueste de eliminar usuario (HomeController)
                    success: function (data) {

                        if (data.resultado) {
                            TablaDatos.row(usuarioseleccionado).remove().draw();
                        }
                        else
                        {
                            swal("El usuario no se a podido eliminar", data.mensaje, "ERROR")
                        }
                    },
                    erro: function (error) {
                        console.log(error)
                    },
                });
            });
            console.log(data);
        });

     // El .val sirve para asigar un valor y obtener un valor
    function Guardar() {
        var Usuario = {
            IdUsuario: $("#txtid").val(),
            Activo: $("#cboactivo").val() === "1",
            Apellidos: $("#txtapellidos").val(),
            Correo: $("#txtcorreo").val(),
            Nombres: $("#txtnombres").val()
        };

        jQuery.ajax({
            url: '@Url.Action("GuardarUsuarios", "Home")',
            type: 'POST',
            data: JSON.stringify({ obj: Usuario }),
            dataType: 'json',
            contentType: "application/json; charset=utf-8",

            // Que queremos que realice mientras se estan ejecutando las acciones de arriba
            beforeSend: function () {
                $(".modal-body").LoadingOverlay("show", {
                    imageResizeFactor: 2,
                    text: "Cargando....",
                    size: 14
                });
            },

            // Cuando la operacion salio bien
            success: function (data) {
                $(".modal-body").LoadingOverlay("hide");

                // Nuevo Usuario
                if (parseInt(Usuario.IdUsuario) === 0) {
                    if (data.resultado != 0) {
                        Usuario.IdUsuario = data.resultado;
                        // Draw sirve para pintar dentro de las filas de la tabla
                        TablaDatos.row.add(Usuario).draw(false);
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                } else {
                    // Modificar Usuario
                    if (data.resultado) {
                        TablaDatos.row(filaSeleccionada).data(Usuario).draw(false);
                        filaSeleccionada = null;
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                }
            },

            error: function (error) {
                $(".modal-body").LoadingOverlay("hide");
                $("#MensajeError").text("Error Ajax");
                $("#MensajeError").show();
            }

        });
    }

    </script>
}
