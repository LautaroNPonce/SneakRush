@using BE
@model List<ErrorVerificacion>
@{
    ViewBag.Title = "Alerta de Integridad";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}


<div class="container mt-5">

    @* Mensaje de éxito al recalcular dígitos *@
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>@TempData["Mensaje"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <div id="mensajeRestauracion"></div>

    @* Alerta roja solo si hay errores *@
    @if (Model != null && Model.Any())
    {
        <div class="alert alert-danger text-center">
           <h2 data-translate="integrity_issues_title">Problemas de integridad detectados</h2>
            <p class="mt-3" data-translate="integrity_issues_message">Se encontraron inconsistencias en los dígitos verificadores (DVH/DVV).</p>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0" data-translate="detected_errors">Errores detectados</h5>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <thead class="table-light">
                        <tr>
                            <th data-translate="column_table">Tabla</th>
                            <th data-translate="column_error_type">Tipo de Error</th>
                            <th data-translate="column_record_id">ID del Registro</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var error in Model)
                        {
                            <tr>
                                <td>@error.Tabla</td>
                                <td>@error.TipoError</td>
                                <td>@(error.IdRegistro.HasValue ? error.IdRegistro.ToString() : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    }
    else
    {
        <div class="alert alert-success text-center">
            <h4 data-translate="no_integrity_issues">No se detectaron errores de integridad.</h4>
        </div>
    }

    <div class="d-flex justify-content-end gap-2">
        <a href="@Url.Action("Index", "HomeWebmaster")" class="btn btn-outline-secondary">
            <i class="fas fa-sign-out-alt" data-translate="btn_cancel"></i> Cancelar
        </a>

        <form method="post" action="@Url.Action("RecalcularDigitos", "AccesoWebmaster")" style="display: inline;">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-sync-alt" data-translate="btn_recalculate"></i> Recalcular DVH/DVV
            </button>
        </form>

        <form id="formRestore" style="display: inline;">
            <label class="btn btn-danger mb-0">
                <i class="fas fa-database" data-translate="btn_restore_backup"></i> Restaurar desde Backup
                <input type="file" name="archivo" accept=".bak" onchange="restaurarBackup(this)" hidden />
            </label>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function restaurarBackup(input) {
            const archivo = input.files[0];
            if (!archivo) return;

            const confirmacion = confirm("¿Estás seguro de que querés restaurar la base de datos?");
            if (!confirmacion) return;

            const formData = new FormData();
            formData.append("archivo", archivo);

            fetch('/BackupRestore/Restore', {
                method: 'POST',
                body: formData
            })
                .then(resp => resp.json())
                .then(data => {
                    const contenedor = document.getElementById("mensajeRestauracion");
                    contenedor.innerHTML = `
                        <div class="alert alert-${data.exito ? 'success' : 'danger'} alert-dismissible fade show mt-3" role="alert">
                            <strong>${data.mensaje}</strong>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    `;

                })
                .catch(err => {
                    alert("Ocurrió un error inesperado.");
                    console.error(err);
                });
        }
    </script>
}
