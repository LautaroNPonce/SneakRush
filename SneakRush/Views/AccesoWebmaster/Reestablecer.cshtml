
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewBag.Title = "Recuperación de Contraseña";
}

<style>
    body {
        background: linear-gradient(to bottom right, #FFD194, #FFAA85);
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
    }
</style>

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow border-0 rounded">
            <!-- 🔹 Encabezado -->
            <div class="card-header text-white text-center" style="background-color: #ff8800;">
                <h4 data-translate="webmaster_reset_title">Recuperación de contraseña</h4>
            </div>

            <!-- 🔹 Cuerpo -->
            <div class="card-body">
                <p class="text-muted text-center mb-4" data-translate="webmaster_reset_instructions">
                    Ingrese su dirección de correo electrónico y le enviaremos su nueva contraseña.
                </p>

                <form action="@Url.Action("Reestablecer", "AccesoWebmaster")" method="post">
                    <div class="mb-3">
                        <label for="correo" class="form-label" data-translate="label_email">Correo electrónico</label>
                        <input class="form-control" id="correo" name="correo" type="email" placeholder="ejemplo@email.com" autocomplete="off" required />
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.Error</div>
                    }

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <a href="@Url.Action("Index", "AccesoWebmaster")"
                           class="small text-decoration-none"
                           style="color: #ff8800;"
                           data-translate="back_to_login">
                            Volver al login
                        </a>

                        <button type="submit"
                                class="btn text-white fw-bold"
                                style="background-color: #ff8800;"
                                data-translate="btn_reset_password">
                            Restablecer contraseña
                        </button>
                    </div>
                </form>
            </div>

            <!-- 🔹 Pie -->
            <div class="card-footer text-center py-3" style="background-color: #fff6ee;">
                <small class="text-muted" data-translate="webmaster_access_notice">
                    Acceso exclusivo para personal autorizado.
                </small>
            </div>
        </div>
    </div>
</div>