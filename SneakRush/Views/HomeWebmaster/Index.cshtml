@{
    ViewBag.Title = "Webmasters";
    Layout = "~/Views/Shared/_LayoutWebmaster.cshtml";
}


<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item">
        <a href="@Url.Action("Index", "HomeWebmaster")" data-translate="breadcrumb_summary">Resumen</a>
    </li>
    <li class="breadcrumb-item active" data-translate="breadcrumb_webmasters">Webmasters</li>
</ol>

<div class="card">
    <div class="card-header">
        <i class="fas fa-user-shield me-1"></i>
        <span data-translate="webmaster_list">Lista de Webmasters</span>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-12">
                <button type="button" class="btn btn-warning" onclick="AbrirModal(null)">
                    <i class="fas fa-user-plus"></i> <span data-translate="btn_new_webmaster">Crear nuevo webmaster</span>
                </button>
            </div>
        </div>

        <hr />
        <table id="tablaWebmasters" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th data-translate="col_name">Nombres</th>
                    <th data-translate="col_lastname">Apellidos</th>
                    <th data-translate="col_email">Correo</th>
                    <th data-translate="col_active">Activo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalFormulario" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="modalLabel" data-translate="webmaster_modal_title">Webmaster</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input id="txtId" type="hidden" value="0" />

                <div class="row g-2">
                    <div class="col-sm-6">
                        <label for="txtNombres" class="form-label" data-translate="label_name">Nombres</label>
                        <input type="text" class="form-control" id="txtNombres" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="txtApellidos" class="form-label" data-translate="label_lastname">Apellidos</label>
                        <input type="text" class="form-control" id="txtApellidos" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="txtCorreo" class="form-label" data-translate="label_email">Correo</label>
                        <input type="email" class="form-control" id="txtCorreo" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="cboActivo" class="form-label" data-translate="label_active">Activo</label>
                        <select class="form-select" id="cboActivo">
                            <option value="1" data-translate="option_yes">Sí</option>
                            <option value="0" data-translate="option_no">No</option>
                        </select>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-12">
                        <div id="mensajeError" class="alert alert-danger" role="alert" data-translate="error_generic" style="display:none">
                            Ocurrió un error, por favor intenta nuevamente.
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                    <span data-translate="btn_close">Cerrar</span>
                </button>
                <button type="button" class="btn btn-success" onclick="Guardar()">
                    <span data-translate="btn_save">Guardar</span>
                </button>
            </div>
        </div>
    </div>
</div>


@section scripts {
    <script>

            var tabla;
            var filaSeleccionada;

            // Detecta el idioma actual (por si estás en inglés o español)
            var idiomaActual = localStorage.getItem("idioma") || "es";

            // URLs de idioma para DataTables
            var urlsIdiomas = {
                "es": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/es-ES.json",
                "en": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/en-GB.json"
            };

            $(document).ready(function () {


                    tabla = $("#tablaWebmasters").DataTable({
                        ajax: {
                            url: '@Url.Action("ListarWebmasters", "HomeWebmaster")',
                            type: 'GET',
                            dataType: 'json'
                        },
                        columns: [
                            { data: "Nombres" },
                            { data: "Apellidos" },
                            { data: "Correo" },
                            {
                                data: "Activo",
                                render: function (data) {
                                    return data ? '<span class="badge bg-success">Si</span>' : '<span class="badge bg-danger">No</span>';
                                }
                            },
                            {
                                defaultContent: '<button class="btn btn-warning btn-sm btn-editar"><i class="fas fa-pen"></i></button> <button class="btn btn-danger btn-sm btn-eliminar ms-2"><i class="fas fa-trash"></i></button>',
                                orderable: false,
                                searchable: false,
                                width: "90px"
                            }
                        ],
                        language: {
                            url: urlsIdiomas[idiomaActual]
                        }
                    });

                    $('#tablaWebmasters tbody').on('click', '.btn-editar', function () {
                        filaSeleccionada = $(this).closest('tr');
                        var data = tabla.row(filaSeleccionada).data();
                        AbrirModal(data);
                    });

                    $('#tablaWebmasters tbody').on('click', '.btn-eliminar', function () {
                        var fila = $(this).closest('tr');
                        var data = tabla.row(fila).data();

                        swal({
                            title: '¿Estás seguro?',
                            text: '¿Deseas eliminar este webmaster?',
                            icon: 'warning',
                            buttons: ["Cancelar", "Sí"],
                            dangerMode: true
                        }).then((willDelete) => {
                            if (willDelete) {
                                $.ajax({
                                    url: '@Url.Action("EliminarWebmaster", "HomeWebmaster")',
                                    type: 'POST',
                                    data: JSON.stringify({ id: data.IdUsuario }),
                                    dataType: 'json',
                                    contentType: "application/json; charset=utf-8",
                                    success: function (data) {
                                        if (data.resultado) {
                                            tabla.row(fila).remove().draw();
                                        } else {
                                            swal("Error", data.mensaje, "error");
                                        }
                                    },
                                    error: function () {
                                        swal("Error", "No se pudo eliminar.", "error");
                                    }
                                });
                            }
                        });
                    });
            });

                function AbrirModal(json) {
                    $("#txtId").val("0");
                    $("#txtNombres").val("");
                    $("#txtApellidos").val("");
                    $("#txtCorreo").val("");
                    $("#cboActivo").val(1);
                    $("#mensajeError").hide();

                    if (json != null) {
                        $("#txtId").val(json.IdUsuario);
                        $("#txtNombres").val(json.Nombres);
                        $("#txtApellidos").val(json.Apellidos);
                        $("#txtCorreo").val(json.Correo);
                        $("#cboActivo").val(json.Activo ? 1 : 0);
                    }

                    $("#modalFormulario").modal("show");
                }

            function Guardar() {
                var usuario = {
                    IdUsuario: $("#txtId").val(),
                    Nombres: $("#txtNombres").val(),
                    Apellidos: $("#txtApellidos").val(),
                    Correo: $("#txtCorreo").val(),
                    Activo: $("#cboActivo").val() === "1",
                    Rol: "Webmaster"
                };

                $.ajax({
                    url: '@Url.Action("GuardarWebmaster", "HomeWebmaster")',
                    type: 'POST',
                    data: JSON.stringify({ obj: usuario }),
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    beforeSend: function () {
                        $(".modal-body").LoadingOverlay("show");
                    },
                    success: function (data) {
                        $(".modal-body").LoadingOverlay("hide");

                        if (data.resultado !== 0 && data.resultado !== false) {
                            usuario.IdUsuario = data.resultado;

                            if (parseInt($("#txtId").val()) === 0) {
                                tabla.row.add(usuario).draw(false);
                            } else {
                                tabla.row(filaSeleccionada).data(usuario).draw(false);
                            }

                            $("#modalFormulario").modal("hide");
                        } else {
                            $("#mensajeError").text(data.mensaje).show();
                        }
                    },
                    error: function () {
                        $(".modal-body").LoadingOverlay("hide");
                        $("#mensajeError").text("Error de conexión.").show();
                    }
                });
        }

        (async function () {
            const idiomaActual = localStorage.getItem('idioma') || 'es';
            await cargarIdioma(idiomaActual);
        })();

    </script>

}
