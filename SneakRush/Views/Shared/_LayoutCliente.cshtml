<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Mi aplicación ASP.NET</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/bootstrap") <!--Puse esto para que me ande el user de nav-item dropdown-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" href="#!" data-translate="store_title">Tienda Online</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page"
                           href="@Url.Action("Index", "TiendaOnline")"
                           data-translate="menu_home">Inicio</a>
                    </li>
                </ul>

                <form class="d-flex">
                    <!-- ComboBox de Idioma -->
                    <div class="me-3 d-flex align-items-center">
                        <select id="comboIdioma" class="form-select form-select-sm"
                                style="width: 120px;" onchange="cambiarIdioma(this.value)">
                            <option value="es">Español 🇪🇸</option>
                            <option value="en">English 🇺🇸</option>
                        </select>
                    </div>

                    @{
                        var cliente = Session["Cliente"] as BE.Cliente;
                        string path = Context.Request.Path.ToLower();
                        bool esVerificarCorreo = path.Contains("/acceso/verificarcorreo");
                    }

                    @if (!esVerificarCorreo)
                    {
                        if (cliente == null)
                        {
                            <a class="btn btn-outline-dark" href="@Url.Action("VerificarCorreo", "Acceso")"
                               data-translate="menu_login">
                                <i class="fas fa-sign-out-alt me-1"></i>Iniciar Sesión
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-dark me-3 position-relative"
                               href="@Url.Action("Carrito", "TiendaOnline")">
                                <i class="fas fa-shopping-cart me-1"></i>
                                <span data-translate="menu_cart">Cart</span>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      id="cantidadcarrito">0</span>
                            </a>

                            <ul class="navbar-nav ms-auto me-0 me-md-3 my-2 my-md-0">
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#"
                                       role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fas fa-user fa-fw"></i>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                        <li><a class="dropdown-item" href="#!"><b>@User.Identity.Name</b></a></li>
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("MisCompras", "TiendaOnline")"
                                               data-translate="menu_my_purchases">Mis compras</a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("CerrarSesion", "AccesoCliente")"
                                               data-translate="menu_logout">Cerrar sesión</a>
                                        </li>
                                    </ul>
                                </li>
                            </ul>
                        }
                    }
                </form>
            </div>
        </div>
    </nav>
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.7/dist/loadingoverlay.min.js"></script>


    @RenderSection("scripts", required: false)

    <script>

    $(document).ready(function () {
        MostrarLaCantidadDelCarrito();
    })
        function MostrarLaCantidadDelCarrito()
        {
            if ($("#cantidadcarrito").length > 0)
            {
                jQuery.ajax({
                    url: '@Url.Action("CantidadCarrito", "TiendaOnline")',
                    type: 'GET',
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    success: function (data)
                    {
                        $("#cantidadcarrito").text(data.cantidad)
                    }
                });
            }
        }
    </script>

    <!-- Este Script es del sistema multidioma -->
    <script>
        document.addEventListener("DOMContentLoaded", async function () {
            // Defino la variable 'combo' antes de usarla
            const combo = document.getElementById('comboIdioma');
            const idiomaGuardado = localStorage.getItem('idioma') || 'es';

            if (combo) {
                combo.value = idiomaGuardado;
                await cargarIdioma(idiomaGuardado);
            }
        });

        async function cambiarIdioma(idioma) {
            localStorage.setItem('idioma', idioma);
            await cargarIdioma(idioma);

            try {
                const response = await fetch(`/Home/CambiarIdioma?codigo=${idioma}`);
                if (!response.ok) {
                    console.error("Error del servidor al cambiar idioma:", response.status);
                } else {
                    console.log("Idioma cambiado correctamente:", idioma);
                    location.reload();
                }
            } catch (error) {
                console.error("Error al llamar a CambiarIdioma:", error);
            }
        }

        async function cargarIdioma(codigo) {
            try {
                // Devuelvo La ruta que debe empezar sin tilde (~)
                const response = await fetch(`/Idiomas/lang_${codigo}.json`);
                const textos = await response.json();

                // Reemplazo los textos en todos los elementos con data-translate
                document.querySelectorAll("[data-translate]").forEach(el => {
                    const key = el.getAttribute("data-translate");
                    if (textos[key]) el.innerText = textos[key];
                });
            } catch (error) {
                console.error("Error al cargar idioma:", error);
            }
        }

    </script>

</body>
</html>



