
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}


<header class="bg-black py-5">
    <div class="container px-4 px-lg-5 my-5">
        <div class="text-center text-white">
            <h1 class="display-4 fw-bolder" data-translate="app_title">SneakRush</h1>
            <p class="lead fw-normal text-white-50 mb-0" data-translate="store_titlee">
                Sneakers exclusivos, al alcance de tus manos
            </p>
        </div>
    </div>
</header>

<div id="carouselZapas" class="carousel slide mb-5" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/Content/Fondos/Fondo1.jpeg" class="d-block w-100" alt="Zapatilla 1" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo2.jpeg" class="d-block w-100" alt="Zapatilla 2" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo3.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo4.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo5.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo6.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo7.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Fondos/Fondo8.jpeg" class="d-block w-100" alt="Zapatilla 3" style="max-height: 500px; object-fit: cover;">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselZapas" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselZapas" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<section>
    <div class="container-fluid px-5  my-5">

        <div class="row">

            <div class="col-sm-3">
                <div class="row mb-3">
                    <div class="col-sm-12">
                        <div class="card">
                            <div class="card-header bg-black text-white" data-translate="sidebar_categories">
                                Categorías
                            </div>
                            <div id="contenedor_categoria" class="card-body"></div>
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-12">
                        <div class="card">
                            <div class="card-header bg-black text-white" data-translate="sidebar_brands">
                                Marcas
                            </div>
                            <div id="contenedor_marca" class="card-body"></div>
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-12">
                        <div class="d-grid gap-2">
                            <button id="btnaplicarfiltro" class="btn btn-outline-black btn-block" type="button" data-translate="btn_apply_filters">
                                <i class="fas fa-filter"></i> Aplicar Filtros
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-sm-9">
                <div id="contenedor_producto" class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
                    <div class="col mb-5">
                        <div class="card h-100">
                            <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="..." />
                            <div class="card-body p-4">
                                <div class="text-center">
                                    <h5 class="fw-bolder">Fancy Product</h5>
                                    $40.00 - $80.00
                                </div>
                            </div>
                            <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                <div class="text-center">
                                    <a class="btn btn-outline-dark mt-auto" href="#" data-translate="btn_view_options">View options</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col mb-5">
                        <div class="card h-100">
                            <div class="badge bg-dark text-white position-absolute" style="top: 0.5rem; right: 0.5rem">Sale</div>
                            <img class="card-img-top" src="https://dummyimage.com/450x300/dee2e6/6c757d.jpg" alt="..." />
                            <div class="card-body p-4">
                                <div class="text-center">
                                    <h5 class="fw-bolder">Special Item</h5>
                                    <div class="d-flex justify-content-center small text-warning mb-2">
                                        <div class="bi-star-fill"></div>
                                        <div class="bi-star-fill"></div>
                                        <div class="bi-star-fill"></div>
                                        <div class="bi-star-fill"></div>
                                        <div class="bi-star-fill"></div>
                                    </div>
                                    <span class="text-muted text-decoration-line-through">$20.00</span>
                                    $18.00
                                </div>
                            </div>
                            <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                <div class="text-center">
                                    <a class="btn btn-outline-dark mt-auto" href="#" data-translate="btn_add_to_cart">Add to cart</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</section>

@section scripts
    {

    <script>

        $(document).ready(function () {

            VerCategorias();
            VerProductos(0, 0);
        })

        function VerCategorias()
        {
            jQuery.ajax({
                url: '@Url.Action("ListarCategorias", "TiendaOnline")',
                type: 'GET',
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (response)
                {
                    $("#contenedor_categoria").LoadingOverlay("hide");

                    $("<div>").addClass("form-check form-switch").append(
                        $("<input>").addClass("form-check-input").attr({
                            "type": "radio",
                            "name": "categoria",
                            "value": "0",
                            "id": "cx",
                            "checked": "checked"
                        }),
                        $("<label>").addClass("form-check-label").text("Todos").attr({ "for": "cx" })
                    ).appendTo("#contenedor_categoria")

                    $.each(response.data, function (i, element) {

                        $("<div>").addClass("form-check form-switch").append(
                            $("<input>").addClass("form-check-input").attr({
                                "type": "radio",
                                "name": "categoria",
                                "value": element.IdCategoria,
                                "id": "c" + i
                            }),
                            $("<label>").addClass("form-check-label").text(element.Descripcion).attr({ "for": "c" + i })
                        ).appendTo("#contenedor_categoria")

                    })

                    VerMarcas();

                },
                beforeSend: function ()
                {
                    $("#contenedor_categoria").LoadingOverlay("show");
                }
            })
        }

        function VerMarcas()
        {
            var _idcategoria = $("input[name=categoria]:checked").val()

            jQuery.ajax({
                url: '@Url.Action("ListarMarcaPorCategoria", "TiendaOnline")',
                type: 'POST',
                data: JSON.stringify({ idcategoria : _idcategoria }),
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (response)
                {
                    $("#contenedor_marca").html("");
                    $("#contenedor_marca").LoadingOverlay("hide");

                    $("<div>").addClass("form-check form-switch").append(
                        $("<input>").addClass("form-check-input").attr({
                            "type": "radio",
                            "name": "marca",
                            "value": "0",
                            "id": "mx",
                            "checked": "checked"
                        }),
                        $("<label>").addClass("form-check-label").text("Todos").attr({ "for": "mx" })
                    ).appendTo("#contenedor_marca")

                    $.each(response.data, function (i, element) {

                        $("<div>").addClass("form-check form-switch").append(
                            $("<input>").addClass("form-check-input").attr({
                                "type": "radio",
                                "name": "marca",
                                "value": element.IdMarca,
                                "id": "m" + i
                            }),
                            $("<label>").addClass("form-check-label").text(element.Descripcion).attr({ "for": "m" + i })
                        ).appendTo("#contenedor_marca")

                    })
                },
                beforeSend: function ()
                {
                    $("#contenedor_marca").LoadingOverlay("show");
                }
            })
        }

        // Esto sirve para que cada vez que seleciones una categoria nos muestra todas las marcas que corresponden a esa categoria
        $(document).on("change", "input[name=categoria]", function () {
            VerMarcas();
        })

        async function VerProductos(_idcategoria, _idmarca) {
            try {
                // Obtenemos el idioma actual desde localStorage
                const idiomaActual = localStorage.getItem('idioma') || 'es';

                // Cargamos el archivo JSON del idioma correspondiente
                const responseTextos = await fetch(`/Idiomas/lang_${idiomaActual}.json`);
                const textos = await responseTextos.json();

                // Llamamos al controlador para obtener los productos
                jQuery.ajax({
                    url: '@Url.Action("ListarProductos", "TiendaOnline")',
                    type: 'POST',
                    data: JSON.stringify({ idcategoria: _idcategoria, idmarca: _idmarca }),
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    success: function (response) {
                        $("#contenedor_producto").html("");
                        $("#contenedor_producto").LoadingOverlay("hide");

                        $.each(response.data, function (i, element) {

                            // Construcción dinámica de las tarjetas de producto
                            const card = $("<div>").addClass("col mb-5").append(
                                $("<div>").addClass("card h-100").append(
                                    $("<img>").addClass("card-img-top").attr({
                                        "src": "data:image/" + element.Extension + ";base64," + element.Base64
                                    }),
                                    $("<div>").addClass("card-body p-4").append(
                                        $("<div>").addClass("text-center").append(
                                            $("<h5>").addClass("fw-bolder").text(element.Nombre),
                                            "$ " + element.Precio.toFixed(2) + "USD"
                                        )
                                    ),
                                    $("<div>").addClass("card-footer p-2 pt-0 border-top-0 bg-transparent").append(
                                        $("<div>").addClass("d-grid gap-2").append(

                                            // Botón Agregar al carrito
                                            @if (Session["Cliente"] != null)
                                            {
                                                @:$("<button>").addClass("btn btn-success mt-auto agregarcarrito").data("idproducto", element.IdProducto).text(textos["add_to_cart"]),
                                                }

                                            // Boton Ver detalle

                                            $("<a>")
                                                .addClass("btn btn-dark mt-auto")
                                                .attr({
                                                    "href": "@Url.Action("DetalleProducto", "TiendaOnline")" + "?idproducto=" + element.IdProducto
                                                })
                                                .text(textos["view_detail"])
                                        )

                                    )

                                )

                            );
                            card.appendTo("#contenedor_producto");

                        });

                    },

                    beforeSend: function () {
                        $("#contenedor_producto").LoadingOverlay("show");
                    }
                });
            } catch (error) {
                console.error("Error al cargar los productos o traducciones:", error);
            }
        }


        // Esta funcion la va a ejecutar el boton de aplicar filtro
        $("#btnaplicarfiltro").click(function () {

            var _idcategoria = $("input[name=categoria]:checked").val()
            var _idmarca = $("input[name=marca]:checked").val()
            VerProductos(_idcategoria, _idmarca)
        })

        // Esta funcion la va a ejecutar el boton agregarcarrito y va agregar un producto al carrito

        $(document).on("click", "button.agregarcarrito", function () {

            console.log($(this).data("idproducto"))

            jQuery.ajax({
                url: '@Url.Action("AgregarCarrito", "TiendaOnline")',
                type: 'POST',
                data: JSON.stringify({ idproducto: $(this).data("idproducto") }),
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (data)
                {
                    if (data.respuesta) {
                        MostrarLaCantidadDelCarrito();

                        swal({
                            title: "Agregado al carrito",
                            text: "¿Desea ingresar al carrito?",
                            type: "success",
                            showCancelButton: true,
                            confirmButtonClass: "btn-primary",
                            confirmButtonText: "Si",
                            cancelButtonText: "No",
                            closeOnConfirm: true
                        }, function () {

                            window.location.href = '@Url.Action("Carrito", "TiendaOnline")'

                        })
                    }
                    else
                    {
                        swal("", data.mensaje, "warning");
                    }
                }
            });
        })

    </script>
}



