@model List<BE.Venta>

@{
    ViewBag.Title = "Mis Compras";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<div class="container mt-5">
    <h2 class="mb-4 text-center" data-translate="my_purchases">Mis Compras</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered shadow-sm rounded bg-white">
                <thead class="table-dark text-center">
                    <tr>
                        <th scope="col" data-translate="id"># ID</th>
                        <th scope="col" data-translate="date">Fecha</th>
                        <th scope="col" data-translate="amount">Monto</th>
                        <th scope="col" data-translate="transaction">Transacción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center align-middle">
                            <td>@item.IdVenta</td>
                            <td>@item.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-success fw-bold">$@item.MontoTotal.ToString("N2")</td>
                            <td>@item.IdTrasferencia</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2"></td>
                        <td class="fw-bold text-success text-center" data-translate="total">
                            Total: $@Model.Sum(x => x.MontoTotal).ToString("N2")
                        </td>
                        <td></td>
                    </tr>
                </tfoot>

            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert" data-translate="no_purchases">
            Aun no realizaste compras.
        </div>
    }
</div>

<style>
    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .table thead th {
        background-color: #343a40;
        color: white;
    }

    .table {
        border-radius: 0.5rem;
        overflow: hidden;
    }
</style>
