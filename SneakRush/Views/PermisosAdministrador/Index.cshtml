@model IEnumerable<SneakRush.Models.VMEntidadPermisos>

@{
    ViewBag.Title = "Gestión de Permisos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<div class="container" style="margin-top:100px;">
    <div class="container-fluid px-4">
        <h2 class="mt-4">Gestión de Permisos</h2>
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Resumen</a></li>
            <li class="breadcrumb-item active">Permisos</li>
        </ol>
        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <form method="get" action="@Url.Action("Index", "PermisosAdministrador")" class="row g-3">

                    <div class="col-md-4">
                        <label class="fw-bold">Filtrar por tipo:</label>
                        <select name="tipo" class="form-select">
                            <option value="" @(ViewBag.TipoFiltro == "" ? "selected" : "")>Todos</option>
                            <option value="Usuario" @(ViewBag.TipoFiltro == "Usuario" ? "selected" : "")>Usuarios (Admin/Webmaster)</option>
                            <option value="Cliente" @(ViewBag.TipoFiltro == "Cliente" ? "selected" : "")>Clientes</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Filtrar por rol:</label>
                        <select name="rol" class="form-select">
                            <option value="" @(ViewBag.RolFiltro == "" ? "selected" : "")>Todos</option>
                            <option value="Administrador" @(ViewBag.RolFiltro == "Administrador" ? "selected" : "")>Administradores</option>
                            <option value="Webmaster" @(ViewBag.RolFiltro == "Webmaster" ? "selected" : "")>Webmasters</option>
                            <option value="Cliente" @(ViewBag.RolFiltro == "Cliente" ? "selected" : "")>Clientes</option>
                        </select>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Aplicar Filtros
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-shield-alt me-1"></i>
                Lista de usuarios y clientes
            </div>

            <div class="card-body">
                <table id="tablaUsuarios" class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Correo</th>
                            <th>Rol</th>
                            <th>Permisos</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.Tipo</td>
                                <td>@u.Nombre</td>
                                <td>@u.Apellido</td>
                                <td>@u.Correo</td>
                                <td>@u.Rol</td>

                                <td>
                                    @if (u.Permisos != null && u.Permisos.Any())
                                    {
                                        <span>@string.Join(", ", u.Permisos.Select(p => p.Nombre))</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin permisos</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("Editar", "PermisosAdministrador", new { id = u.Id, tipo = u.Tipo })"
                                       class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>