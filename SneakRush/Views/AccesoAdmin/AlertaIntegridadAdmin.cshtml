@{
    ViewBag.Title = "Advertencia de integridad";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var errores = ViewBag.Errores as List<string>;
}

<div class="container mt-5">
    <div class="alert alert-warning text-center shadow-sm">
        <h2 data-translate="integrity_warning_title">Advertencia de integridad detectada</h2>
        <p class="mt-3" data-translate="integrity_warning_desc">
            Se encontraron inconsistencias en los dígitos verificadores.
        </p>
    </div>

    <div class="alert alert-danger mt-4 shadow-sm">
        <strong data-translate="integrity_important">Importante:</strong>
        <span data-translate="integrity_important_desc">
            Comunicá este problema al webmaster para que realice la verificación o restauración correspondiente.
        </span>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header bg-warning text-white">
            <h5 class="mb-0" data-translate="integrity_errors_title">Errores encontrados</h5>
        </div>
        <div class="card-body">
            @if (errores != null && errores.Any())
            {
                <ul class="list-group">
                    @foreach (var error in errores)
                    {
                        <li class="list-group-item text-danger">
                            <i class="fas fa-exclamation-circle me-2 text-warning"></i> @error
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-success" data-translate="integrity_no_errors">
                    No se detectaron errores de integridad.
                </p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            <i class="fas fa-arrow-right"></i>
            <span data-translate="continue_system">Continuar al sistema</span>
        </a>
    </div>
</div>
