
@{
    ViewBag.Title = "Categoria";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item">
        <a href="index.html" data-translate="breadcrumb_maintenance">Mantenimiento</a>
    </li>
    <li class="breadcrumb-item active" data-translate="breadcrumb_categories">Categoría</li>
</ol>

<div class="card">
    <div class="card-header">
        <span data-translate="categories_title">Lista de Categorías</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <button type="button" class="btn btn-warning" onclick="AbrirModelo(null)">
                    <span data-translate="btn_new_category">Agregar una nueva categoría</span>
                </button>
            </div>
        </div>

        <hr />
        <table id="Tabla1" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th data-translate="col_description">Descripción</th>
                    <th data-translate="col_active">Activo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="ModeloFormulario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="exampleModalLabel" data-translate="modal_category_title">Categoría</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <input id="txtid" type="hidden" value="0" />

                <div class="row g-1">

                    <div class="col-sm-6">
                        <label for="txtdescripcion" class="form-label" data-translate="label_description">Descripción</label>
                        <input type="text" class="form-control" id="txtdescripcion" autocomplete="off">
                    </div>

                    <div class="col-sm-6">
                        <label for="cboactivo" class="form-label">Activo</label>
                        <select class="form-select" id="cboactivo">
                            <option value="1" data-translate="option_yes">Sí</option>
                            <option value="0" data-translate="option_no">No</option>
                        </select>
                    </div>
                </div>

                <!--Mensaje de Alerta-->
                <div class="row mt-2">
                    <div class="col-12">

                        <div id="MensajeError" class="alert alert-danger" role="alert">
                            A simple danger alert—check it out!
                        </div>

                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal" data-translate="btn_close">Cerrar</button>
                <button type="button" class="btn btn-success" onclick="Guardar()" data-translate="btn_save">Guardar</button>
            </div>

        </div>
    </div>
</div>



<!---Todo lo que se escriba aca lo va a heredar el Master Page(Que esta en _Layout.cshtml)-->
@section scripts {
<script>

    var TablaDatos;
    var filaSeleccionada;

    // Detecta el idioma actual (por si estás en inglés o español)
    var idiomaActual = localStorage.getItem("idioma") || "es";

    // URLs de idioma para DataTables
    var urlsIdiomas = {
        "es": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/es-ES.json",
        "en": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/en-GB.json"
    };


     // # Identificador para el atributo Id
    TablaDatos = $("#Tabla1").DataTable({
        ajax: {
            url: '@Url.Action("ListarCategoria", "Mantenimiento")',
            type: 'GET',
            dataType: 'json'
        },
        columns: [
            { data: "Descripcion" },
            {
                data: "Activo",
                render: function (data) {
                    if (data) {
                        return '<span class="badge rounded-pill bg-success">Si</span>';
                    } else {
                        return '<span class="badge rounded-pill bg-danger">No</span>';
                    }
                }
            },
            {
                defaultContent:
                    '<button type="button" class="btn btn-warning btn-sm btn-modificar"><i class="fas fa-pen"></i></button>' +
                    '<button type="button" class="btn btn-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash"></i></button>',
                orderable: false,
                searchable: false,
                width: "90px"
            }
        ],
        language: {
            url: urlsIdiomas[idiomaActual]
        }
    });

      // Abrir Modelo va a recibir un objeto llamado json que es mi "data"
        function AbrirModelo(json) {

        $("#txtid").val("0");
        $("#txtdescripcion").val("");
        $("#cboactivo").val(1);

        $("#MensajeError").hide();

        if (json != null) {
            $("#txtid").val(json.IdCategoria);
            $("#txtdescripcion").val(json.Descripcion);
            $("#cboactivo").val(json.Activo === true ? 1 : 0);
        }

        $("#ModeloFormulario").modal("show");
    }

    // Botón Modificar
    $("#Tabla1 tbody").on("click", '.btn-modificar', function () {
        filaSeleccionada = $(this).closest("tr");
        var data = TablaDatos.row(filaSeleccionada).data();
        AbrirModelo(data);
    });


        // Botón Eliminar
        $("#Tabla1 tbody").on("click", '.btn-eliminar', function () {
            var categoriaseleccionado = $(this).closest("tr");
            var data = TablaDatos.row(categoriaseleccionado).data();

            swal({
                title: 'Estas seguro?',
                text: '¿Deseas eliminar esta categoria?',
                type: 'warning',
                showCancelButton: true,
                confirmButtonClass: 'btn-primary',
                confirmButtonText: 'Si',
                cancelButtonText: 'No',
                closeOnConfirm: true
            },
            function () {

                jQuery.ajax({
                    url: '@Url.Action("EliminarCategoria", "Mantenimiento")',
                    type: 'POST',
                    data: JSON.stringify({id: data.IdCategoria}),
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    // este data esta almacenando la respueste de eliminar usuario (HomeController)
                    success: function (data) {

                        if (data.resultado) {
                            TablaDatos.row(categoriaseleccionado).remove().draw();
                        }
                        else
                        {
                            swal("La categoria no se a podido eliminar", data.mensaje, "ERROR")
                        }
                    },
                    erro: function (error) {
                        console.log(error)
                    },
                });
            });
            console.log(data);
        });

     // El .val sirve para asigar un valor y obtener un valor
        function Guardar() {

        var Categoria = {
            IdCategoria: $("#txtid").val(),
            Activo: $("#cboactivo").val() === "1",
            Descripcion: $("#txtdescripcion").val()
        };

        jQuery.ajax({
            url: '@Url.Action("GuardarCategoria", "Mantenimiento")',
            type: 'POST',
            data: JSON.stringify({ obj: Categoria }),
            dataType: 'json',
            contentType: "application/json; charset=utf-8",

            // Que queremos que realice mientras se estan ejecutando las acciones de arriba
            beforeSend: function () {
                $(".modal-body").LoadingOverlay("show", {
                    imageResizeFactor: 2,
                    text: "Cargando....",
                    size: 14
                });
            },

            // Cuando la operacion salio bien
            success: function (data) {
                $(".modal-body").LoadingOverlay("hide");

                // Nueva Categoria
                if (parseInt(Categoria.IdCategoria) === 0) {

                    if (data.resultado != 0) {

                        Categoria.IdCategoria = data.resultado;
                        // Draw sirve para pintar dentro de las filas de la tabla
                        TablaDatos.row.add(Categoria).draw(false);
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                } else {

                    // Modificar Categoria
                    if (data.resultado) {
                        TablaDatos.row(filaSeleccionada).data(Categoria).draw(false);
                        filaSeleccionada = null;
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                }
            },

            error: function (error) {
                $(".modal-body").LoadingOverlay("hide");
                $("#MensajeError").text("Error Ajax");
                $("#MensajeError").show();
            }

        });
    }

    // Agrego esta linea para recargar las traducciones visibles
        (async function () {
            const idiomaActual = localStorage.getItem('idioma') || 'es';
            await cargarIdioma(idiomaActual);
        })();

    </script>
}

