
@{
    ViewBag.Title = "Producto";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<ol class="breadcrumb mb-4 mt-4">
    <li class="breadcrumb-item">
        <a href="index.html" data-translate="breadcrumb_maintenance">Mantenimiento</a>
    </li>
    <li class="breadcrumb-item active" data-translate="breadcrumb_product">Productos</li>
</ol>

<div class="card">
    <div class="card-header">
        <span data-translate="product_title">Lista de Productos</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <button type="button" class="btn btn-warning" data-translate="btn_new_product" onclick="AbrirModelo(null)">Agregar un nuevo producto</button>

                <a href="/VerProductosConStock.aspx" target="_blank" class="btn btn-outline-primary ms-2">
                    <span data-translate="btn_view_xml">Ver productos con stock en XML</span>
                </a>

                <a href="/VerProductosConStock.aspx?download=1" class="btn btn-outline-success ms-2">
                    <span data-translate="btn_download_xml">Descargar XML</span>
                </a>


            </div>
        </div>

        <hr />
        <table id="Tabla1" class="display cell-border" style="width: 100%">
            <thead>
                <tr>
                    <th data-translate="col_name">Nombre</th>
                    <th data-translate="col_description">Descripción</th>
                    <th data-translate="col_brand">Marca</th>
                    <th data-translate="col_category">Categoría</th>
                    <th data-translate="col_price">Precio</th>
                    <th data-translate="col_stock">Stock</th>
                    <th data-translate="col_active">Activo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="ModeloFormulario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h1 class="modal-title fs-5" id="exampleModalLabel" data-translate="modal_product_title">Producto</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <input id="txtid" type="hidden" value="0" />

                <form id="contenedor" class="row">

                    <div class="col-sm-3">
                        <div class="mb-2">
                            <img id="ImgProducto" height="197" width="200" class="border rounded mx-auto d-block img-fluid" />
                        </div>
                        <div class="mb-2">
                            <input class="form-control" type="file" id="fileProducto" accept="image/png, image/jpg, image/jpeg" onchange="MostrarImagen(this)"/>
                        </div>
                    </div>

                    <div class="col-sm-3">
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_name">Nombre</label>
                            <input type="text" class="form-control" id="txtnombre" name="nombre" autocomplete="off"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_description">Descripción</label>
                            <textarea type="text" class="form-control" id="txtdescripcion" name="descripcion" style="height:125px;resize:none"></textarea>
                        </div>
                    </div>

                    <div class="col-sm-3">
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_brand">Marca</label>
                            <select id="cbomarca" class="form-select">
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_category">Categoría</label>
                            <select id="cbocategoria" class="form-select">
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_price">Precio</label>
                            <input type="text" class="form-control" id="txtprecio" name="precio" autocomplete="off"/>
                        </div>
                    </div>

                    <div class="col-sm-3">
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_stock">Stock</label>
                            <input type="number" class="form-control" id="txtstock" name="stock" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" data-translate="label_active">Activo</label>
                            <select id="cboactivo" class="form-select">
                                <option value="1" data-translate="option_yes">Sí</option>
                                <option value="0" data-translate="option_no">No</option>
                            </select>
                        </div>
                    </div>
                </form>

                <!--Mensaje de Alerta-->
                <div class="row mt-2">
                    <div class="col-12">

                        <div id="MensajeError" class="alert alert-danger" role="alert">
                        </div>

                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal" data-translate="btn_close">Cerrar</button>
                <button type="button" class="btn btn-success" onclick="Guardar()" data-translate="btn_save">Guardar</button>
            </div>

        </div>
    </div>
</div>


<!---Todo lo que se escriba aca lo va a heredar el Master Page(Que esta en _Layout.cshtml)-->
@section scripts {
    <script>

        var TablaDatos;
        var filaSeleccionada;

        var TablaDatos;
        var filaSeleccionada;

        // Detecta el idioma actual (por si estás en inglés o español)
        var idiomaActual = localStorage.getItem("idioma") || "es";

        // URLs de idioma para DataTables
        var urlsIdiomas = {
            "es": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/es-ES.json",
            "en": "https://cdn.datatables.net/plug-ins/2.3.1/i18n/en-GB.json"
        };


        function MostrarImagen(input)
        {
            if (input.files)
            {
                var reader = new FileReader();
                reader.onload = function (l)
                {
                    $("#ImgProducto").attr("src",l.target.result).width(200).height(197)
                }
                reader.readAsDataURL(input.files[0]);
            }
        }


     // # Identificador para el atributo Id
    TablaDatos = $("#Tabla1").DataTable({
        ajax: {
            url: '@Url.Action("ListarProducto", "Mantenimiento")',
            type: 'GET',
            dataType: 'json'
        },
        columns: [
            { data: "Nombre" },
            { data: "Descripcion" },
            {
                data: "oMarca",
                render: function (data) {
                   return data.Descripcion
                }
            },
            {
                data: "oCategoria",
                render: function (data) {
                    return data.Descripcion
                }
            },
            { data: "Precio" },
            { data: "Stock" },
            {
                data: "Activo",
                render: function (data) {
                    if (data) {
                        return '<span class="badge rounded-pill bg-success">Si</span>';
                    } else {
                        return '<span class="badge rounded-pill bg-danger">No</span>';
                    }
                }
            },
            {
                defaultContent:
                    '<button type="button" class="btn btn-warning btn-sm btn-modificar"><i class="fas fa-pen"></i></button>' +
                    '<button type="button" class="btn btn-danger btn-sm ms-2 btn-eliminar"><i class="fas fa-trash"></i></button>',
                orderable: false,
                searchable: false,
                width: "90px"
            }
        ],
        language: {
            url: urlsIdiomas[idiomaActual]
        }
    });

    $.ajax({
    url: '@Url.Action("ListarMarca", "Mantenimiento")',
    type: 'GET',
    data: null,
    dataType: 'json',
    contentType: "application/json; charset=utf-8",

    success: function (data) {

        $("<option>").attr({ "value": "0","disabled": true }).text("Seleccionar").appendTo("#cbomarca");

        $.each(data.data, function (index, valor)
        {
            $("<option>").attr({ "value": valor.IdMarca }).text(valor.Descripcion).appendTo("#cbomarca");
        })
    },
    error: function (error) {
        console.log(error);
    }
    });


    $.ajax({
    url: '@Url.Action("ListarCategoria", "Mantenimiento")',
    type: 'GET',
    data: null,
    dataType: 'json',
    contentType: "application/json; charset=utf-8",

    success: function (data) {

        $("<option>").attr({ "value": "0", "disabled": true }).text("Seleccionar").appendTo("#cbocategoria");

        $.each(data.data, function (index, valor) {
            $("<option>").attr({ "value": valor.IdCategoria }).text(valor.Descripcion).appendTo("#cbocategoria");
        })
    },
    error: function (error) {
        console.log(error);
    }
    });

        // Comando para validar precios decimales
        jQuery.validator.addMethod("preciodecimal", function (value, element) {
            return this.optional(element) || /^\d{0,4}(\.\d{0,2})?$/.test(value);
        }, "El formato correcto del precio es ##.##");

        $("#contenedor").validate({
            rules: {
                nombre: {
                    required: true
                },
                descripcion: {
                    required: true
                },
                precio: {
                    required: true,
                    preciodecimal: true
                },
                stock: {
                    required: true,
                    number: true
                },
            },
            messages: {
                nombre: "- El campo nombre es obligatorio",
                descripcion: "- El campo descripcion es obligatorio",
                precio: { required: "- El campo precio es obligatorio", preciodecimal: "- El formato correcto del precio es ##.##" },
                stock: { required: "- El campo stock es obligatorio", preciodecimal: "- Debe ingresar solo numeros" },
            },
            errorElement: "div",
            errorLabelContainer: ".alert-danger"
        })

      // Abrir Modelo va a recibir un objeto llamado json que es mi "data"
        function AbrirModelo(json) {

        $("#txtid").val("0");
        $("#ImgProducto").removeAttr("src");
        $("#fileProducto").val("");
        $("#txtnombre").val("");
        $("#txtdescripcion").val("");
        $("#cbomarca").val($("#cbomarca option:first").val());
        $("#cbocategoria").val($("#cbocategoria option:first").val());
        $("#txtprecio").val("");
        $("#txtstock").val("");
        $("#cboactivo").val(1);

        $("#MensajeError").hide();

        if (json != null) {

            $("#txtid").val(json.IdProducto);
            $("#txtnombre").val(json.Nombre);
            $("#txtdescripcion").val(json.Descripcion);
            $("#cbomarca").val(json.oMarca.IdMarca);
            $("#cbocategoria").val(json.oCategoria.IdCategoria);
            $("#txtprecio").val(json.Precio);
            $("#txtstock").val(json.Stock);
            $("#cboactivo").val(json.Activo === true ? 1 : 0);

            jQuery.ajax({
                url: '@Url.Action("ImagenProducto", "Mantenimiento")',
                type: 'POST',
                data: JSON.stringify({ id: json.IdProducto }),
                dataType: 'json',
                contentType: "application/json; charset=utf-8",
                success: function (data) {

                    $("#ImgProducto").LoadingOverlay("hide");

                    if (data.conversion)
                    {
                        $("#ImgProducto").attr("src", "data:image/" + data.extension + ";base64," + data.textoBase64);

                    }
                },
                error: function (error)
                {
                    $("#ImgProducto").LoadingOverlay("hide");
                    $("#MensajeError").show();
                    $("#MensajeError").text("Error al mostrar imagen. ¡¡¡Intente nuevamente!!!");
                },
                beforeSend: function ()
                {
                    $("#ImgProducto").LoadingOverlay("show");
                },
            });

        }

        $("#ModeloFormulario").modal("show");
    }

    // Botón Modificar
    $("#Tabla1 tbody").on("click", '.btn-modificar', function () {
        filaSeleccionada = $(this).closest("tr");
        var data = TablaDatos.row(filaSeleccionada).data();
        AbrirModelo(data);
    });


        // Botón Eliminar
        $("#Tabla1 tbody").on("click", '.btn-eliminar', function () {
            var productoseleccionado = $(this).closest("tr");
            var data = TablaDatos.row(productoseleccionado).data();

            swal({
                title: 'Estas seguro?',
                text: '¿Deseas eliminar este producto?',
                type: 'warning',
                showCancelButton: true,
                confirmButtonClass: 'btn-primary',
                confirmButtonText: 'Si',
                cancelButtonText: 'No',
                closeOnConfirm: true
            },
            function () {

                jQuery.ajax({
                    url: '@Url.Action("EliminarProducto", "Mantenimiento")',
                    type: 'POST',
                    data: JSON.stringify({id: data.IdProducto}),
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    // este data esta almacenando la respueste de eliminar usuario (HomeController)
                    success: function (data) {

                        if (data.resultado) {
                            TablaDatos.row(productoseleccionado).remove().draw();
                        }
                        else
                        {
                            swal("La marca no se a podido eliminar", data.mensaje, "ERROR")
                        }
                    },
                    erro: function (error) {
                        console.log(error)
                    },
                });
            });
            console.log(data);
        });


     // El .val sirve para asigar un valor y obtener un valor
        function Guardar() {

            if (!$("#contenedor").valid())
            {
                return;
            }
            var ImagenSeleccionada = $("#fileProducto")[0].files[0];

            var Producto = {
                IdProducto: $("#txtid").val(),
                Nombre: $("#txtnombre").val(),
                Descripcion: $("#txtdescripcion").val(),
                oMarca: {
                    IdMarca: $("#cbomarca option:selected").val(),
                    Descripcion: $("#cbomarca option:selected").text()
                },
                oCategoria: {
                    IdCategoria: $("#cbocategoria option:selected").val(),
                    Descripcion: $("#cbocategoria option:selected").text()
                },
                PrecioSerie: $("#txtprecio").val(),
                Precio: $("#txtprecio").val(),
                Stock: $("#txtstock").val(),
                Activo: $("#cboactivo").val() === "1" ? true : false
            };


            var request = new FormData();
            request.append("objeto", JSON.stringify(Producto));
            request.append("archivoImagen", ImagenSeleccionada);


        jQuery.ajax({
            url: '@Url.Action("GuardarProducto", "Mantenimiento")',
            type: 'POST',
            data: request,
            processData: false,
            contentType: false,

            // Que queremos que realice mientras se estan ejecutando las acciones de arriba
            beforeSend: function () {
                $(".modal-body").LoadingOverlay("show", {
                    imageResizeFactor: 2,
                    text: "Cargando....",
                    size: 14
                });
            },

            // Cuando la operacion salio bien
            success: function (data) {
                $(".modal-body").LoadingOverlay("hide");

                // Nuevo Producto
                if (Producto.IdProducto == 0)
                {

                    if (data.IdGenerado != 0)
                    {
                        Producto.IdProducto = data.IdGenerado;
                        // Draw sirve para pintar dentro de las filas de la tabla
                        TablaDatos.row.add(Producto).draw(false);
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                } else {

                    // Modificar Producto
                    if (data.OperacioExitosa) {
                        TablaDatos.row(filaSeleccionada).data(Producto).draw(false);
                        filaSeleccionada = null;
                        $("#ModeloFormulario").modal("hide");
                    } else {
                        $("#MensajeError").text(data.mensaje);
                        $("#MensajeError").show();
                    }
                }
            },

            error: function (error) {
                $(".modal-body").LoadingOverlay("hide");
                $("#MensajeError").text("Error Ajax");
                $("#MensajeError").show();
            }

        });
        }

        // Agrego esta linea para recargar las traducciones visibles
        (async function () {
            const idiomaActual = localStorage.getItem('idioma') || 'es';
            await cargarIdioma(idiomaActual);
        })();

    </script>
}

